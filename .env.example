# ----------------------------------------------------------------------
# Banco de dados (PostgreSQL) — use Neon, Supabase ou Postgres local
# ----------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/barbearia?schema=public"

# ----------------------------------------------------------------------
# Auth.js (NextAuth) — gere com: npx auth secret
# ----------------------------------------------------------------------
AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_URL="http://localhost:3000"

# Login social opcional (Google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ----------------------------------------------------------------------
# E-mail (Resend) — notificações de confirmação e lembrete
# ----------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Barbearia <agenda@suabarbearia.com>"

# ----------------------------------------------------------------------
# App
# ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------
# Fuso horário (IMPORTANTE em produção)
# O cálculo de horários e do expediente usa o horário LOCAL do processo.
# Em hosts UTC (ex.: Vercel), defina TZ para o fuso da barbearia, senão
# os horários exibidos ficarão deslocados.
# ----------------------------------------------------------------------
TZ="America/Sao_Paulo"
